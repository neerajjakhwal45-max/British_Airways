      <column caption='Aircraft Clean' datatype='string' name='[Calculation_2394481825558528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([aircraft],&apos;/&apos;) THEN&#13;&#10;SPLIT([aircraft],&apos;/&apos;,1)&#13;&#10;ELSEIF CONTAINS([aircraft],&apos;and&apos;) THEN&#13;&#10;SPLIT([aircraft],&apos;and&apos;,1)&#13;&#10;ELSE &#13;&#10;   ([aircraft])&#13;&#10;END' />
      </column>
      <column caption='Above Avg Sales' datatype='boolean' name='[Calculation_2394481831530497]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([csat_score])&gt;=WINDOW_AVG(SUM([csat_score]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
